# Required environment variables for mcp-typebot
# Copy this file to .env and fill in your values
TYPEBOT_API_KEY=

# Optional: for self-hosted Typebot instances
# Set to your instance URL (e.g. https://bot.example.com)
# If not set, defaults to Typebot Cloud (app.typebot.io / typebot.io)
# TYPEBOT_BASE_URL=
